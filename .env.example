# =============================================================================
# CRM for Company Management — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ─── Django Core ─────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production-use-50-plus-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── Database ────────────────────────────────────────────────────────────────
# Local Docker: postgresql://crm_user:changeme@localhost:5432/crm_db
# CI:          postgresql://crm_user:crm_password@localhost:5432/crm_test
DATABASE_URL=postgresql://crm_user:changeme@localhost:5432/crm_db

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Email (Resend / SMTP) ───────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ─── Stripe (Payments) ───────────────────────────────────────────────────────
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Supabase (if used for frontend auth / storage) ──────────────────────────
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Google Gemini (AI Proxy) ────────────────────────────────────────────────
# GEMINI_API_KEY=AIza...

# ─── Turkish Payment Gateway (Iyzico) ────────────────────────────────────────
# IYZICO_API_KEY=...
# IYZICO_SECRET_KEY=...
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ─── Turkish SMS Gateway (Netgsm) ────────────────────────────────────────────
# NETGSM_USERCODE=...
# NETGSM_PASSWORD=...
# NETGSM_MSGHEADER=...

# ─── Sentry (Error Tracking) ───────────────────────────────────────────────────
# SENTRY_DSN=https://...@....ingest.sentry.io/...

# ─── AWS S3 / DigitalOcean Spaces (Media Storage) ──────────────────────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_STORAGE_BUCKET_NAME=...
# AWS_S3_ENDPOINT_URL=...

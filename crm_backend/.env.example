# Django
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_PASSWORD=local-dev-password-change-me
DATABASE_URL=postgresql://crm_user:local-dev-password-change-me@db:5432/crm_db

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email (Resend)
RESEND_EMAIL_USER=your-resend-user
RESEND_EMAIL_API_KEY=your-resend-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Turkish Payment Gateway (İyzico)
IYZICO_API_KEY=your-iyzico-key
IYZICO_API_SECRET=your-iyzico-secret

# Turkish SMS (İleti Merkezi)
SMS_API_KEY=your-sms-key
SMS_API_SECRET=your-sms-secret
SMS_SENDER=CRM

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket
AWS_S3_ENDPOINT_URL=https://s3.eu-central-003.backblazeb2.com
AWS_S3_REGION_NAME=eu-central-003

# Sentry
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=1.0.0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL
FRONTEND_URL=http://localhost:3000
